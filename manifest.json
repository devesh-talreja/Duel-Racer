{
  "manifest_version": 3,
  "name": "Duel Racer",
  "version": "1.0.0",
  "description": "1v1 duel car racing game - Race against the NPC through 10 challenging levels!",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Duel Racer"
  },
  "permissions": [
    "storage"
  ]
}
